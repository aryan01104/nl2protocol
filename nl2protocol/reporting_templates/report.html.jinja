<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>nl2protocol report — {{ timestamp }}</title>
<style>
  /* ───────── Layout ───────── */
  :root {
    --col-instruction: #e63946;   /* vivid red, arrow color */
    --col-config:      #9d4edd;   /* purple, reserved for labware-resolver viz */
    --col-domain:      #ffb703;   /* gold */
    --col-inferred:    #fb8500;   /* orange */
    --bg:              #fdf6e3;   /* warm off-white */
    --panel:           #ffffff;
    --ink:             #1a1a1a;
    --dim:             #6b6b6b;
    --grid:            #e5e0d4;

    /* Per-citation palette (8 vivid, distinguishable hues). Each unique
       cited_text in the instruction hashes to one slot; both the cite
       span (instruction column) and the atomic value span (spec column)
       share the hue. Saturated for legibility against the off-white
       background — designed to be picked out at a glance. */
    --palette-0: #c1272d;   /* deep red */
    --palette-1: #e76f1c;   /* burnt orange */
    --palette-2: #c79100;   /* mustard */
    --palette-3: #4f8a2b;   /* leaf green */
    --palette-4: #168a8a;   /* teal */
    --palette-5: #1f5fa6;   /* deep blue */
    --palette-6: #5d3fa8;   /* indigo */
    --palette-7: #b62f7a;   /* magenta */
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font: 14px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
  }
  header {
    padding: 24px 32px 16px;
    border-bottom: 1px solid var(--grid);
  }
  header h1 {
    margin: 0 0 4px;
    font-size: 20px;
    font-weight: 600;
  }
  header .meta {
    color: var(--dim);
    font-size: 13px;
  }
  .legend {
    display: flex; gap: 18px; margin-top: 12px; flex-wrap: wrap;
    font-size: 12px;
  }
  .legend .swatch {
    display: inline-block; width: 12px; height: 12px;
    border-radius: 2px; margin-right: 6px; vertical-align: middle;
  }

  /* ───────── 5-column grid ─────────
     Per ADR-0011 Phase 2a, the report renders five columns matching the
     pipeline's user-visible transformation milestones:
       1. Instruction
       2. Extracted Spec (post-extraction, immutable LLM output)
       3. Resolved Spec  (post-orchestrator gap resolution)
       4. Validated Spec (post-stage-5 CompleteProtocolSpec promotion)
       5. Generated Python
     Column 3 + column 4 are visually similar — both render provenanced
     spec values — but encode different stages of the pipeline. Phase 2b
     adds cross-column arrows showing each value's resolution journey. */
  .grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr 1.15fr 1.15fr 1.4fr;
    gap: 14px;
    padding: 24px 32px;
    min-height: calc(100vh - 200px);
  }
  .col {
    background: var(--panel);
    border: 1px solid var(--grid);
    border-radius: 6px;
    padding: 16px;
    overflow-y: auto;
    max-height: 80vh;
  }
  .col h2 {
    margin: 0 0 12px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--dim);
    border-bottom: 1px solid var(--grid);
    padding-bottom: 8px;
  }

  /* ───────── Provenance color spans ─────────
     Two visual languages must NOT compete:
       - per-citation color → atomic instruction-sourced values; the same
                              hue lights both the cite span in the instruction
                              and the value span in the spec, so readers
                              connect them by hue rather than by arrow.
       - dotted underline   → values filled in by the model (domain_default
                              / inferred / config). Color stays categorical
                              by source kind. The underline tells readers
                              "this isn't a literal lift from the user."
       - arrow              → composite (step-existence) grounding only. */
  .prov-instruction    { font-weight: 500; cursor: help; /* hue comes from .palette-N */ }
  .prov-config         { color: var(--col-config);      font-weight: 500; cursor: help; text-decoration: underline dotted; text-underline-offset: 3px; }
  .prov-domain_default { color: var(--col-domain);      font-weight: 500; cursor: help; text-decoration: underline dotted; text-underline-offset: 3px; }
  .prov-inferred       { color: var(--col-inferred);    font-weight: 500; cursor: help; text-decoration: underline dotted; text-underline-offset: 3px; }

  /* ▴ marker prepended to non-instruction atomic values, repeated in the
     legend. Visual at-a-glance shorthand: "this value isn't a literal lift
     from the user — the model filled it in." Sized large enough to spot
     at column-scan distance, colored with --col-inferred so it reads as
     "model-filled" without any palette context. */
  .non-instr-marker {
    display: inline-block;
    margin-right: 4px;
    font-size: 14px;
    line-height: 1;
    color: var(--col-inferred);
    transform: translateY(1px);
  }

  /* ───────── Review-lifecycle badges (ADR-0009) ─────────
     The Provenance carries `review_status` (original / reviewed_agree /
     reviewed_disagree / user_confirmed / user_edited /
     user_accepted_suggestion / user_skipped). Only the two
     attention-worthy states get an inline badge; everything else surfaces
     in the tooltip.

       reviewed_disagree → red ⚠ superscript ("the reviewer pushed back here")
       user_edited       → blue ✎ marker     ("the user touched this value")

     Other non-default states (reviewed_agree, user_accepted_suggestion,
     user_confirmed, user_skipped) get the prov-review-* class for tooltip
     consumers but no inline glyph — they're positive/passive states and
     don't deserve column-scan attention. */
  .prov-review-reviewed-disagree::after {
    content: "⚠";
    margin-left: 3px;
    font-size: 10px;
    color: var(--col-instruction);
    vertical-align: super;
    font-weight: 700;
  }
  .prov-review-user-edited::after {
    content: "✎";
    margin-left: 3px;
    font-size: 11px;
    color: #1f5fa6;
    vertical-align: baseline;
  }

  /* ───────── Per-citation palette ─────────
     `.palette-N` paints the text for both:
       - .cite-marker.cite-atomic-color in the instruction column
       - .prov-instruction value spans in the spec column
     Same hue on both sides == same cited_text on both sides. */
  .palette-0 { color: var(--palette-0); }
  .palette-1 { color: var(--palette-1); }
  .palette-2 { color: var(--palette-2); }
  .palette-3 { color: var(--palette-3); }
  .palette-4 { color: var(--palette-4); }
  .palette-5 { color: var(--palette-5); }
  .palette-6 { color: var(--palette-6); }
  .palette-7 { color: var(--palette-7); }

  /* Hover-flip: when a cite-marker becomes "cite-active" (because the
     reader is hovering its matching value-span in the spec column), the
     cite span fills with its palette color and the text flips to a
     hardcoded contrast shade (white for dark hues, ink for light hues).
     The flip is done by overriding text color and adding a strong bg
     of the same palette hue. Per-palette contrast is hardcoded — chosen
     once for legibility, not computed. */
  .cite-marker.cite-atomic-color.palette-0.cite-active { background: var(--palette-0); color: #fff; }
  .cite-marker.cite-atomic-color.palette-1.cite-active { background: var(--palette-1); color: #fff; }
  .cite-marker.cite-atomic-color.palette-2.cite-active { background: var(--palette-2); color: #1a1a1a; }
  .cite-marker.cite-atomic-color.palette-3.cite-active { background: var(--palette-3); color: #fff; }
  .cite-marker.cite-atomic-color.palette-4.cite-active { background: var(--palette-4); color: #fff; }
  .cite-marker.cite-atomic-color.palette-5.cite-active { background: var(--palette-5); color: #fff; }
  .cite-marker.cite-atomic-color.palette-6.cite-active { background: var(--palette-6); color: #fff; }
  .cite-marker.cite-atomic-color.palette-7.cite-active { background: var(--palette-7); color: #fff; }

  /* ───────── Instruction column ───────── */
  .instruction-text {
    white-space: pre-wrap;
    font-family: ui-serif, Georgia, "Times New Roman", serif;
    font-size: 14px;
    line-height: 1.6;
  }

  /* ───────── Spec / step rendering ───────── */
  .step {
    margin-bottom: 14px;
    padding: 10px 12px;
    border-left: 3px solid transparent;
    background: rgba(0, 0, 0, 0.015);
    border-radius: 0 4px 4px 0;
  }
  .step.step-orphan { border-left-color: var(--col-inferred); background: rgba(251, 133, 0, 0.05); }
  .step.step-grounded-instruction { border-left-color: var(--col-instruction); }
  .step.step-grounded-mixed { border-left-color: var(--col-domain); }
  .step-header {
    font-size: 12px;
    color: var(--dim);
    margin-bottom: 6px;
    font-style: italic;
    cursor: help;
  }
  .step-action {
    font-weight: 600;
    margin-bottom: 4px;
    color: var(--ink);
  }
  .step-detail {
    margin-left: 12px;
    font-size: 13px;
    color: #333;
  }
  .step-detail .label { color: var(--dim); margin-right: 4px; }
  /* Footnote inside a step block — used for the `note` field on
     pause/comment steps so the body isn't empty. Small, dim, italic. */
  .step-note {
    margin-top: 6px;
    padding-top: 5px;
    border-top: 1px dashed var(--grid);
    font-size: 11px;
    font-style: italic;
    color: var(--dim);
    line-height: 1.4;
  }
  /* Step blocks are themselves hoverable — the JS tooltip surfaces
     the justification + optional domain expansion. */
  .step { cursor: help; }

  /* ───────── Code column ───────── */
  pre.code {
    margin: 0;
    font-family: ui-monospace, "SF Mono", Menlo, Monaco, "Courier New", monospace;
    font-size: 12px;
    line-height: 1.45;
    white-space: pre;
    overflow-x: auto;
    color: #1a1a1a;
  }

  /* ───────── Cite markers in instruction ─────────
     Three cite kinds, three treatments:
       composite-step  → arrow ANCHOR. Subtle underline (muted red) at
                         rest, brightens on hover; pairs with the SVG
                         arrow into the step block. Multiple step cites
                         can share one anchor (fan-out arrows).
       atomic-color    → COLOR MATCH. The .palette-N class on the same
                         span paints the substring the same hue as the
                         atomic value in the spec column — no arrow.
       q2-cohesion     → ON-HOVER hint. Invisible at rest; tints when
                         its step block is hovered, showing which
                         instruction fragments answer "why these
                         parameters cohere as one step." */
  .cite-marker {
    cursor: pointer;
    padding: 0 1px;
    transition: background 0.12s, border-color 0.12s;
  }
  .cite-composite-step {
    background: rgba(184, 68, 79, 0.05);
    border-bottom: 2px solid rgba(184, 68, 79, 0.45);
  }
  .cite-composite-step:hover,
  .cite-composite-step.cite-active {
    background: rgba(184, 68, 79, 0.18);
    border-bottom-color: rgba(184, 68, 79, 0.85);
  }
  .cite-atomic-color {
    /* color comes from the .palette-N class on the same span */
    font-weight: 500;
  }
  .cite-atomic-color:hover,
  .cite-atomic-color.cite-active {
    background: rgba(0, 0, 0, 0.06);
    border-radius: 2px;
  }
  .cite-q2-cohesion {
    /* deliberately unstyled at rest — reads as plain prose */
    transition: background 0.15s;
  }
  .cite-q2-cohesion.q2-active {
    background: rgba(184, 68, 79, 0.10);
    border-radius: 2px;
  }
  .step.step-active {
    background: rgba(184, 68, 79, 0.06);
    border-left-color: var(--col-instruction);
  }
  span[data-prov-id]:hover,
  span[data-prov-id].prov-active {
    outline: 1px solid currentColor;
    outline-offset: 1px;
    border-radius: 2px;
  }

  /* ───────── JS hover tooltip (replaces native title=) ───────── */
  #hover-tip {
    position: fixed;
    z-index: 100;
    max-width: 360px;
    padding: 10px 12px;
    background: #2a2a2a;
    color: #f5f5f5;
    font-size: 12px;
    line-height: 1.45;
    border-radius: 4px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.18s ease;
    white-space: normal;
  }
  #hover-tip.visible { opacity: 1; }
  #hover-tip .tip-meta {
    color: #b8b8b8;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }
  #hover-tip .tip-cite {
    font-style: italic;
    color: #ffd9c2;
    margin-bottom: 6px;
  }
  #hover-tip .tip-reasoning { color: #f0f0f0; }
  #hover-tip .tip-section { margin-top: 8px; }
  /* Indented blockquote of the step's cited text. The left bar uses the
     step-trigger color (vivid red for instruction grounding) so readers
     see "this is the literal phrase that triggered the step" without
     needing the inline cite-id attr. */
  #hover-tip .tip-quote {
    margin: 8px 0 0;
    padding: 4px 0 4px 10px;
    border-left: 3px solid var(--col-instruction);
    color: #ffd9c2;
    font-style: italic;
    line-height: 1.4;
  }
  /* When step_palette_class is set, the left bar takes that hue. */
  #hover-tip .tip-quote.palette-0 { border-left-color: var(--palette-0); }
  #hover-tip .tip-quote.palette-1 { border-left-color: var(--palette-1); }
  #hover-tip .tip-quote.palette-2 { border-left-color: var(--palette-2); }
  #hover-tip .tip-quote.palette-3 { border-left-color: var(--palette-3); }
  #hover-tip .tip-quote.palette-4 { border-left-color: var(--palette-4); }
  #hover-tip .tip-quote.palette-5 { border-left-color: var(--palette-5); }
  #hover-tip .tip-quote.palette-6 { border-left-color: var(--palette-6); }
  #hover-tip .tip-quote.palette-7 { border-left-color: var(--palette-7); }
  /* Reviewer-objection box uses the instruction-red bar to signal "flagged
     concern, attention needed" — distinct from the step-blockquote palettes. */
  #hover-tip .tip-objection {
    margin: 8px 0 0;
    padding: 4px 0 4px 10px;
    border-left: 3px solid var(--col-instruction);
    color: #ffd9c2;
    font-style: italic;
    line-height: 1.4;
  }

  /* ───────── SVG arrow overlay ─────────
     The overlay hosts TWO arrow categories:
       - Composite-step arrows (instruction → extracted spec block).
         Reserved for step-existence grounding; existing pre-Phase-2b
         language. Default red (--col-instruction).
       - Resolution arrows (extracted spec atomic value → resolved
         spec atomic value). One per gap_resolved event with a
         drawable resolution_kind. Per ADR-0011 Phase 2b. Color-coded
         per resolution kind. */
  #arrow-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 50;
  }
  #arrow-overlay path {
    fill: none;
    stroke: var(--col-instruction);
    stroke-opacity: 0.32;
    stroke-width: 2.5;
    transition: stroke-opacity 0.12s, stroke-width 0.12s;
  }
  #arrow-overlay path.arrow-active {
    stroke-opacity: 0.9;
    stroke-width: 3.5;
  }

  /* Resolution arrows (extracted → resolved column).
     Color encodes how the gap was resolved:
       auto_accepted             → subtle green   (no human attention needed)
       user_accepted_suggestion  → gray-green     (human confirmed the suggester)
       user_edited               → blue           (human typed a new value)
       user_confirmed            → soft gray      (human confirmed without change)
     Stroke width slightly thinner than composite-step arrows so the
     two categories visually separate. */
  #arrow-overlay path.resolution-arrow {
    stroke-width: 2;
    stroke-opacity: 0.35;
  }
  #arrow-overlay path.resolution-arrow.arrow-active {
    stroke-opacity: 0.9;
    stroke-width: 3;
  }
  #arrow-overlay path.res-auto_accepted            { stroke: #4f8a2b; }  /* leaf green */
  #arrow-overlay path.res-user_accepted_suggestion { stroke: #6b8e3d; }  /* gray-green */
  #arrow-overlay path.res-user_edited              { stroke: #1f5fa6; }  /* deep blue */
  #arrow-overlay path.res-user_confirmed           { stroke: #6b6b6b; }  /* dim gray */

  /* ───────── Footer ───────── */
  footer {
    padding: 16px 32px 24px;
    border-top: 1px solid var(--grid);
    color: var(--dim);
    font-size: 12px;
    display: flex;
    justify-content: space-between;
  }
  footer a { color: var(--dim); }
</style>
</head>
<body>

<header>
  <h1>nl2protocol report</h1>
  <div class="meta">
    Generated {{ timestamp }} ·
    Status: {% if success %}<strong style="color:#2a9d8f">success</strong>{% else %}<strong style="color:var(--col-instruction)">failed</strong>{% endif %}
    {% if prov_stats and prov_stats.total %}
      · <span title="Atomic values whose provenance is NOT a literal lift from the instruction (i.e. domain default / inferred / config). Higher = more was filled in by the model.">{{ prov_stats.total }} atomic values · <strong>{{ "%.0f"|format(prov_stats.non_instr_pct) }}%</strong> non-instruction (model-filled)</span>
    {% endif %}
  </div>
  <div class="legend">
    <span><span class="swatch" style="background: var(--col-instruction)"></span>→ arrow = step decomposition (instruction phrase → spec step)</span>
    <span style="color: var(--dim); font-style: italic;">instruction-sourced atoms: per-citation hue (same hue on cite + value)</span>
    <span><span class="non-instr-marker">▴</span> non-instruction atom (filled in by model — domain default / inferred / config)</span>
    <span style="color: var(--col-instruction); font-weight: 700;">⚠</span><span style="margin-left: 4px;"> reviewer disagreed (hover for objection)</span>
    <span style="color: #1f5fa6;">✎</span><span style="margin-left: 4px;"> user-edited during gap resolution</span>
  </div>
</header>

<div class="grid">

  <!-- ───────── Column 1: Instruction ───────── -->
  <div class="col">
    <h2>Instruction</h2>
    <div class="instruction-text">{{ instruction_html|safe }}</div>
  </div>

  <!-- ───────── Column 2: Extracted Spec ─────────
       Step blocks no longer print "triggered by:" — the arrow communicates
       the same thing. Hover the block for justification + reasoning. -->
  <div class="col col-extracted-spec">
    <h2>Extracted Spec</h2>
    {% if spec_steps %}
      {% for step in spec_steps %}
        <div class="step {{ step.step_class }}"
             data-prov-id="{{ step.step_trigger_prov_id }}"
             data-step-cited="{{ step.step_cited_text|e }}"
             data-step-palette="{{ step.step_palette_class }}"
             {% if step.step_reasoning %}data-step-reasoning="{{ step.step_reasoning|e }}"{% endif %}
             data-params-reasoning="{{ step.parameters_reasoning|e }}"
             data-confidence="{{ step.confidence }}">
          <div class="step-action">Step {{ step.order }}: {{ step.action }}</div>
          {% for line in step.detail_lines %}
            <div class="step-detail">{{ line|safe }}</div>
          {% endfor %}
          {% if step.note_line %}{{ step.note_line|safe }}{% endif %}
        </div>
      {% endfor %}
    {% else %}
      <p style="color: var(--dim)">(extraction did not produce a spec)</p>
    {% endif %}
  </div>

  <!-- ───────── Column 3: Resolved Spec (post-orchestrator) ─────────
       The spec AFTER the orchestrator's gap-resolution loop converges.
       Every Gap that was resolvable is filled; every Provenance carries
       the review_status from ADR-0009. Distinct from column 4 (Validated
       Spec) — column 3 is the orchestrator's output; column 4 is the
       same spec after stage-3.5's labware confirmation panel + stage-4's
       constraint check pass. ADR-0011 Phase 2a introduces the split. -->
  <div class="col col-resolved-spec">
    <h2>Resolved Spec</h2>
    {% if resolved_steps %}
      {% for step in resolved_steps %}
        <div class="step {{ step.step_class }}"
             data-step-cited="{{ step.step_cited_text|e }}"
             data-step-palette="{{ step.step_palette_class }}"
             {% if step.step_reasoning %}data-step-reasoning="{{ step.step_reasoning|e }}"{% endif %}
             data-params-reasoning="{{ step.parameters_reasoning|e }}"
             data-confidence="{{ step.confidence }}">
          <div class="step-action">Step {{ step.order }}: {{ step.action }}</div>
          {% for line in step.detail_lines %}
            <div class="step-detail">{{ line|safe }}</div>
          {% endfor %}
          {% if step.note_line %}{{ step.note_line|safe }}{% endif %}
        </div>
      {% endfor %}
    {% else %}
      <p style="color: var(--dim)">(orchestrator stage not reached)</p>
    {% endif %}
  </div>

  <!-- ───────── Column 4: Validated Spec (post-CompleteProtocolSpec) ─────────
       The spec after the stage-3.5 labware-confirm panel (legacy
       _confirm_labware_assignments still serves this until ADR-0011
       Phase 5) AND the stage-4 ConstraintChecker.check_all pass. This
       is the spec that becomes CompleteProtocolSpec at the type-system
       level. Visually similar to column 3 today; Phase 2b's arrows will
       show what changed (labware re-mappings + any constraint clips). -->
  <div class="col col-validated-spec">
    <h2>Validated Spec</h2>
    {% if validated_steps %}
      {% for step in validated_steps %}
        <div class="step {{ step.step_class }}"
             data-step-cited="{{ step.step_cited_text|e }}"
             data-step-palette="{{ step.step_palette_class }}"
             {% if step.step_reasoning %}data-step-reasoning="{{ step.step_reasoning|e }}"{% endif %}
             data-params-reasoning="{{ step.parameters_reasoning|e }}"
             data-confidence="{{ step.confidence }}">
          <div class="step-action">Step {{ step.order }}: {{ step.action }}</div>
          {% for line in step.detail_lines %}
            <div class="step-detail">{{ line|safe }}</div>
          {% endfor %}
          {% if step.note_line %}{{ step.note_line|safe }}{% endif %}
        </div>
      {% endfor %}
    {% else %}
      <p style="color: var(--dim)">(validation stage not reached)</p>
    {% endif %}
  </div>

  <!-- ───────── Column 5: Generated Code ───────── -->
  <div class="col">
    <h2>Generated Python</h2>
    {% if generated_script %}
      <pre class="code">{{ generated_script|e }}</pre>
    {% else %}
      <p style="color: var(--dim)">(script-generation stage not reached)</p>
    {% endif %}
  </div>

</div>

<footer>
  <span>nl2protocol · provenance-traced protocol generation</span>
  <span>Hover any colored value or step block for the original cite + reasoning.</span>
</footer>

<!-- JS hover tooltip — replaces native title= for richer formatting and fade. -->
<div id="hover-tip" role="tooltip"></div>

<!-- SVG overlay for arrows from instruction-cite spans to spec-step blocks.
     The clipPath is rebuilt on every render to match the spec column's
     visible rect — arrows that would extend above/below the column box
     are clipped, preserving their bezier shape but hiding the overflow. -->
<svg id="arrow-overlay" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <clipPath id="arrow-clip"><rect id="arrow-clip-rect" x="0" y="0" width="0" height="0"/></clipPath>
  </defs>
  <!-- Composite-step arrows (instruction → extracted spec). Clipped to the
       extracted-spec column so off-screen segments don't visually escape. -->
  <g clip-path="url(#arrow-clip)" id="arrow-paths"></g>
  <!-- Resolution arrows (extracted → resolved spec, ADR-0011 Phase 2b).
       NOT clipped — the relevant region spans columns 2 and 3, both
       always in view at desktop widths. -->
  <g id="resolution-arrow-paths"></g>
</svg>

<!-- ADR-0011 Phase 2b: resolution-arrow data embedded as JSON.
     One entry per drawable gap_resolved event. The JS at the end of
     this document parses this on init + on every layout-affecting
     event, then draws an SVG path per entry. -->
<script id="resolution-arrows-data" type="application/json">{{ resolution_arrows_json|default('[]')|safe }}</script>

<script>
(function () {
  // Visual wiring for the report:
  //   1. Composite-step arrows — one SVG bezier per (step, anchor) pair.
  //      A single instruction cite-span can carry MULTIPLE step-trigger
  //      ids (space-separated in data-cite-id) when two step cites
  //      overlap; in that case we draw N arrows fanning out from the
  //      same anchor, producing the "<"-shaped attribution.
  //   2. Hover emphasis — hovering a cite OR a prov target outlines the
  //      pair across all DOM segments sharing the id, and brightens the
  //      matching arrow(s).
  //   3. Q2 cohesion hover — hovering a step block tints every
  //      .cite-q2-cohesion span tagged with that step's id; lit-up
  //      state is the only time Q2 cites become visible.
  //   4. Hover tooltip — replaces native title=. Reads provenance from
  //      data-prov-* attrs on value spans and data-step-* / data-params-*
  //      on step blocks; positions near the cursor with a fade.

  const overlay = document.getElementById("arrow-overlay");
  const tip = document.getElementById("hover-tip");
  if (!overlay) return;

  // Token-match selector: a span's data-cite-id may carry multiple
  // ids ("s0-step-trigger s1-step-trigger") so use the ~= attribute
  // selector for whitespace-separated tokens.
  const sel = (attr, token) => `[${attr}~="${CSS.escape(token)}"]`;

  function bezierPath(srcRect, dstRect) {
    // Right edge of source → left edge of destination, smooth horizontal sweep.
    const x1 = srcRect.right;
    const y1 = srcRect.top + srcRect.height / 2;
    const x2 = dstRect.left;
    const y2 = dstRect.top + dstRect.height / 2;
    const dx = Math.max(40, (x2 - x1) * 0.5);
    return `M ${x1} ${y1} C ${x1 + dx} ${y1}, ${x2 - dx} ${y2}, ${x2} ${y2}`;
  }

  function renderArrows() {
    const arrowGroup = document.getElementById("arrow-paths");
    if (arrowGroup) {
      while (arrowGroup.firstChild) arrowGroup.removeChild(arrowGroup.firstChild);
    }
    // Update the clip-path rect to match the spec column's visible bounds.
    // Arrows that would extend above/below the column get clipped without
    // changing their bezier shape.
    const specCol = document.querySelector(".col-extracted-spec");
    const clipRect = document.getElementById("arrow-clip-rect");
    if (specCol && clipRect) {
      const r = specCol.getBoundingClientRect();
      // Extend left toward the instruction column so the arrow's starting
      // bezier sweep remains visible — only the destination side needs clipping.
      const leftExtend = window.innerWidth;
      clipRect.setAttribute("x", String(r.left - leftExtend));
      clipRect.setAttribute("y", String(r.top));
      clipRect.setAttribute("width", String(r.right - r.left + leftExtend));
      clipRect.setAttribute("height", String(r.bottom - r.top));
    }
    // Dedupe by step-trigger id: one arrow per (cite-anchor, step) pair.
    // When the same step-trigger id appears across multiple DOM segments
    // (because of overlap segmentation), pick the leftmost segment as anchor.
    const anchorByStepId = new Map();
    document.querySelectorAll(".cite-composite-step[data-cite-id]").forEach((citeEl) => {
      const ids = (citeEl.getAttribute("data-cite-id") || "").split(/\s+/).filter(Boolean);
      const r = citeEl.getBoundingClientRect();
      if (!r.width) return;
      ids.forEach((id) => {
        if (!id.endsWith("-step-trigger")) return;
        const prev = anchorByStepId.get(id);
        if (!prev || r.left < prev.rect.left) {
          anchorByStepId.set(id, { rect: r });
        }
      });
    });
    anchorByStepId.forEach(({ rect: srcRect }, id) => {
      const target = document.querySelector(`.step${sel("data-prov-id", id)}`);
      if (!target) return;
      const dstRect = target.getBoundingClientRect();
      if (!dstRect.width) return;
      const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
      path.setAttribute("d", bezierPath(srcRect, dstRect));
      path.dataset.citeId = id;
      (arrowGroup || overlay).appendChild(path);
    });
  }

  function setPairActive(id, active) {
    // Toggle highlight on every cite-segment, prov-target, and arrow sharing one id.
    document.querySelectorAll(sel("data-cite-id", id)).forEach((e) =>
      e.classList.toggle("cite-active", active)
    );
    document.querySelectorAll(sel("data-prov-id", id)).forEach((e) => {
      if (e.classList.contains("step")) {
        e.classList.toggle("step-active", active);
      } else {
        e.classList.toggle("prov-active", active);
      }
    });
    overlay.querySelectorAll(`path[data-cite-id="${CSS.escape(id)}"]`).forEach((p) =>
      p.classList.toggle("arrow-active", active)
    );
  }

  function setQ2Active(stepId, active) {
    document.querySelectorAll(sel("data-q2-step-id", stepId)).forEach((e) =>
      e.classList.toggle("q2-active", active)
    );
  }

  // ────────── Hover tooltip ──────────
  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, (c) => ({
      "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
    }[c]));
  }

  function showTip(html, evt) {
    if (!tip) return;
    tip.innerHTML = html;
    tip.classList.add("visible");
    moveTip(evt);
  }
  function hideTip() {
    if (!tip) return;
    tip.classList.remove("visible");
  }
  function moveTip(evt) {
    if (!tip || !tip.classList.contains("visible")) return;
    const pad = 14;
    const w = tip.offsetWidth;
    const h = tip.offsetHeight;
    let x = evt.clientX + pad;
    let y = evt.clientY + pad;
    if (x + w > window.innerWidth - 8) x = evt.clientX - pad - w;
    if (y + h > window.innerHeight - 8) y = evt.clientY - pad - h;
    tip.style.left = `${Math.max(8, x)}px`;
    tip.style.top = `${Math.max(8, y)}px`;
  }

  function tooltipHtmlForValueSpan(el) {
    // Atomic value tooltip:
    //   header line:  "SOURCE: <kind> · CONFIDENCE: <pct> · REVIEW: <state-glyph>"
    //   for instruction-sourced values: cited substring as a quoted line.
    //   for non-instruction values: TWO labeled rows:
    //     [WHY THIS VALUE]      positive_reasoning
    //     [WHY NOT IN INSTR]    why_not_in_instruction
    //   when review_status == 'reviewed_disagree': boxed reviewer objection.
    const source = el.getAttribute("data-prov-source") || "unknown";
    const conf = el.getAttribute("data-prov-confidence") || "";
    const cited = el.getAttribute("data-prov-cited");
    const positiveReasoning = el.getAttribute("data-prov-positive-reasoning")
                              || el.getAttribute("data-prov-reasoning");
    const whyNotInInstruction = el.getAttribute("data-prov-why-not-in-instruction");
    const reviewStatus = el.getAttribute("data-prov-review-status") || "original";
    const reviewerObjection = el.getAttribute("data-prov-reviewer-objection");
    const confPct = conf ? `${Math.round(parseFloat(conf) * 100)}%` : "";

    // Compact glyph + label per review state. 'original' is the default
    // state and gets no extra meta — the source/confidence pair is enough.
    const reviewGlyph = ({
      reviewed_agree:           "✓ reviewer agreed",
      reviewed_disagree:        "✗ reviewer disagreed",
      user_confirmed:           "✓ confirmed",
      user_edited:              "✎ edited by user",
      user_accepted_suggestion: "→ accepted suggestion",
      user_skipped:             "↷ skipped",
    })[reviewStatus] || "";

    let parts = [
      `<div class="tip-meta">source: ${escapeHtml(source)}${confPct ? ` · confidence: ${confPct}` : ""}${reviewGlyph ? ` · ${escapeHtml(reviewGlyph)}` : ""}</div>`,
    ];
    if (cited) {
      parts.push(`<div class="tip-cite">"${escapeHtml(cited)}"</div>`);
    }
    if (positiveReasoning) {
      parts.push(`<div class="tip-section"><div class="tip-meta">why this value</div><div class="tip-reasoning">${escapeHtml(positiveReasoning)}</div></div>`);
    }
    if (whyNotInInstruction) {
      parts.push(`<div class="tip-section"><div class="tip-meta">why not in instruction</div><div class="tip-reasoning">${escapeHtml(whyNotInInstruction)}</div></div>`);
    }
    if (reviewerObjection) {
      parts.push(`<div class="tip-section"><div class="tip-meta">reviewer objection</div><blockquote class="tip-objection">${escapeHtml(reviewerObjection)}</blockquote></div>`);
    }
    return parts.join("");
  }

  function tooltipHtmlForStepBlock(el) {
    // Step block tooltip:
    //   header: "WHY THIS STEP, WITH THESE PARAMS? · <confidence>"
    //   reasoning paragraph (parameters_reasoning)
    //   indented blockquote of step_cited_text with palette-colored left bar
    //   optional "DOMAIN EXPANSION" section when step_reasoning is present
    const cited = el.getAttribute("data-step-cited") || "";
    const paletteCls = el.getAttribute("data-step-palette") || "";
    const stepReasoning = el.getAttribute("data-step-reasoning");
    const paramsReasoning = el.getAttribute("data-params-reasoning");
    const conf = el.getAttribute("data-confidence") || "";
    let parts = [`<div class="tip-meta">why this step, with these params?${conf ? ` · ${escapeHtml(conf)}` : ""}</div>`];
    if (paramsReasoning) {
      parts.push(`<div class="tip-reasoning">${escapeHtml(paramsReasoning)}</div>`);
    }
    if (cited) {
      parts.push(`<blockquote class="tip-quote ${escapeHtml(paletteCls)}">${escapeHtml(cited)}</blockquote>`);
    }
    if (stepReasoning) {
      parts.push(`<div class="tip-section"><div class="tip-meta">domain expansion</div><div class="tip-reasoning">${escapeHtml(stepReasoning)}</div></div>`);
    }
    return parts.join("");
  }

  function wireHover() {
    // Cite ↔ prov pair highlight + cite-segment tooltip (if cite carries
    // any prov metadata via the value side, which it doesn't directly —
    // tooltip wiring lives on prov-id targets and step blocks below).
    document.querySelectorAll("[data-cite-id]").forEach((el) => {
      const ids = (el.getAttribute("data-cite-id") || "").split(/\s+/).filter(Boolean);
      el.addEventListener("mouseenter", () => ids.forEach((id) => setPairActive(id, true)));
      el.addEventListener("mouseleave", () => ids.forEach((id) => setPairActive(id, false)));
    });

    // Atomic value spans (carry data-prov-source) — pair highlight + tooltip.
    document.querySelectorAll("[data-prov-source]").forEach((el) => {
      const id = el.getAttribute("data-prov-id");
      el.addEventListener("mouseenter", (e) => {
        if (id) setPairActive(id, true);
        showTip(tooltipHtmlForValueSpan(el), e);
      });
      el.addEventListener("mousemove", moveTip);
      el.addEventListener("mouseleave", () => {
        if (id) setPairActive(id, false);
        hideTip();
      });
    });

    // Step blocks — Q2 cohesion lighting + step-trigger pair highlight + tooltip.
    document.querySelectorAll(".step[data-prov-id]").forEach((stepEl) => {
      const provId = stepEl.getAttribute("data-prov-id");
      const stepId = provId.replace(/-step-trigger$/, "");
      stepEl.addEventListener("mouseenter", (e) => {
        setPairActive(provId, true);
        setQ2Active(stepId, true);
        showTip(tooltipHtmlForStepBlock(stepEl), e);
      });
      stepEl.addEventListener("mousemove", moveTip);
      stepEl.addEventListener("mouseleave", () => {
        setPairActive(provId, false);
        setQ2Active(stepId, false);
        hideTip();
      });
    });

    // Complete-spec column step blocks (no data-prov-id but still hover tooltip).
    document.querySelectorAll(".step:not([data-prov-id])[data-step-cited]").forEach((stepEl) => {
      stepEl.addEventListener("mouseenter", (e) => showTip(tooltipHtmlForStepBlock(stepEl), e));
      stepEl.addEventListener("mousemove", moveTip);
      stepEl.addEventListener("mouseleave", hideTip);
    });

    // Reverse Q2 wiring: hovering a Q2 cite-span surfaces its step.
    document.querySelectorAll(".cite-q2-cohesion[data-q2-step-id]").forEach((citeEl) => {
      const stepIds = (citeEl.getAttribute("data-q2-step-id") || "").split(/\s+/).filter(Boolean);
      citeEl.addEventListener("mouseenter", () => stepIds.forEach((sid) => {
        setQ2Active(sid, true);
        setPairActive(`${sid}-step-trigger`, true);
      }));
      citeEl.addEventListener("mouseleave", () => stepIds.forEach((sid) => {
        setQ2Active(sid, false);
        setPairActive(`${sid}-step-trigger`, false);
      }));
    });
  }

  // ────────── ADR-0011 Phase 2b: resolution arrows ──────────
  // Read the embedded JSON, draw one bezier path per drawable
  // gap_resolved event from extracted-spec column to resolved-spec
  // column. Color encodes resolution_kind via CSS class.
  function readResolutionArrowData() {
    const el = document.getElementById("resolution-arrows-data");
    if (!el) return [];
    try {
      const data = JSON.parse(el.textContent || "[]");
      return Array.isArray(data) ? data : [];
    } catch (e) {
      return [];
    }
  }

  function renderResolutionArrows() {
    const group = document.getElementById("resolution-arrow-paths");
    if (!group) return;
    while (group.firstChild) group.removeChild(group.firstChild);
    const arrows = readResolutionArrowData();
    if (arrows.length === 0) return;
    const extractedCol = document.querySelector(".col-extracted-spec");
    const resolvedCol  = document.querySelector(".col-resolved-spec");
    if (!extractedCol || !resolvedCol) return;
    arrows.forEach((arrow) => {
      const pid = arrow.prov_id;
      // Source: the value cell in the extracted-spec column with the
      // matching data-prov-id. Destination: the value cell in the
      // resolved-spec column with the same id. Per-column scoping
      // keeps the cross-column lookup unambiguous (same prov_id appears
      // once per column).
      const src = extractedCol.querySelector(sel("data-prov-id", pid));
      const dst = resolvedCol.querySelector(sel("data-prov-id", pid));
      if (!src || !dst) return;
      const srcRect = src.getBoundingClientRect();
      const dstRect = dst.getBoundingClientRect();
      if (!srcRect.width || !dstRect.width) return;
      const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
      path.setAttribute("d", bezierPath(srcRect, dstRect));
      path.setAttribute("class", `resolution-arrow res-${arrow.resolution_kind}`);
      path.dataset.provId = pid;
      path.dataset.resolutionKind = arrow.resolution_kind;
      group.appendChild(path);
    });
  }

  function scheduleRender() {
    requestAnimationFrame(() => {
      renderArrows();
      renderResolutionArrows();
    });
  }

  function init() {
    renderArrows();
    renderResolutionArrows();
    wireHover();
    // Re-render on every layout-affecting event so arrows track their anchors.
    window.addEventListener("resize", scheduleRender);
    window.addEventListener("scroll", scheduleRender, { passive: true });
    document.querySelectorAll(".col").forEach((c) =>
      c.addEventListener("scroll", scheduleRender, { passive: true })
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
})();
</script>

</body>
</html>
