{
  "id": "ex_casual_db10465f",
  "intent": "Set up a sample normalization workflow where you first add diluent to a deepwell plate, then the robot pauses so you can add your neat samples where it tells you to. After that, it does a bunch of dilutions across the plate, mixing each step, and finally transfers the normalized samples to three separate plates",
  "config": {
    "labware": {
      "deepwell plate": {
        "load_name": "thermofisherabgene_96_wellplate_2200ul",
        "slot": "8"
      }
    },
    "pipettes": {
      "p1000_mount": {
        "model": "p1000_single_gen2",
        "tipracks": []
      },
      "m300_mount": {
        "model": "p300_multi_gen2",
        "tipracks": []
      }
    }
  },
  "style": "casual",
  "source_file": "normalization.ot2.apiv2.py",
  "output_schema": {
    "protocol_name": "Normalization",
    "author": "Nick <protocols@opentrons.com>",
    "labware": [
      {
        "slot": "8",
        "load_name": "thermofisherabgene_96_wellplate_2200ul",
        "label": "deepwell plate"
      }
    ],
    "pipettes": [
      {
        "mount": "p1000_mount",
        "model": "p1000_single_gen2",
        "tipracks": []
      },
      {
        "mount": "m300_mount",
        "model": "p300_multi_gen2",
        "tipracks": []
      }
    ],
    "modules": [],
    "commands": [
      {
        "command_type": "pick_up_tip",
        "pipette": "m300_mount"
      },
      {
        "command_type": "aspirate",
        "pipette": "left",
        "volume": "vol_per_trans"
      },
      {
        "command_type": "dispense",
        "pipette": "left",
        "volume": "vol_per_trans"
      },
      {
        "command_type": "transfer",
        "pipette": "m300_mount",
        "volume": 200,
        "source_labware": "",
        "source_well": "A1",
        "dest_labware": "",
        "dest_well": "A1",
        "new_tip": "never"
      },
      {
        "command_type": "drop_tip",
        "pipette": "m300_mount"
      },
      {
        "command_type": "pause",
        "pipette": "left",
        "message": "sample_str"
      },
      {
        "command_type": "pick_up_tip",
        "pipette": "p1000_mount"
      },
      {
        "command_type": "mix",
        "pipette": "left",
        "repetitions": 5,
        "volume": 200
      },
      {
        "command_type": "drop_tip",
        "pipette": "left"
      },
      {
        "command_type": "mix",
        "pipette": "left",
        "repetitions": 5,
        "volume": 200
      },
      {
        "command_type": "transfer",
        "pipette": "p1000_mount",
        "volume": "final_vol",
        "source_labware": "",
        "source_well": "A1",
        "dest_labware": "",
        "dest_well": "A1",
        "new_tip": "always"
      }
    ]
  }
}