{
  "id": "ex_casual_1ca80a97",
  "intent": "Take samples from multiple 96-well plates and spot them onto microscope slides using a multichannel pipette. The robot will wash and dry the pipette tips between each sample by dipping them in wash solutions and touching blotting paper. It repeats this for all your samples, creating arrays of spots on the slides.",
  "config": {
    "labware": {
      "slides": {
        "load_name": "gracebiolabsflexwell",
        "slot": "2"
      },
      "pin wash reservoir": {
        "load_name": "axygen_4_reservoir_73000ul",
        "slot": "11"
      },
      "blot paper reservoir": {
        "load_name": "customblotpaper_1_reservoir_870000ul",
        "slot": "8"
      },
      "tiprack300": {
        "load_name": "tip_type",
        "slot": "10"
      }
    },
    "pipettes": {
      "m300_mount": {
        "model": "p300_multi_gen2",
        "tipracks": [
          "tiprack300"
        ]
      }
    }
  },
  "style": "casual",
  "source_file": "spotting.ot2.apiv2.py",
  "output_schema": {
    "protocol_name": "Slide Array Spotting",
    "author": "Nick <protocols@opentrons.com>",
    "labware": [
      {
        "slot": "2",
        "load_name": "gracebiolabsflexwell",
        "label": "slides"
      },
      {
        "slot": "11",
        "load_name": "axygen_4_reservoir_73000ul",
        "label": "pin wash reservoir"
      },
      {
        "slot": "8",
        "load_name": "customblotpaper_1_reservoir_870000ul",
        "label": "blot paper reservoir"
      },
      {
        "slot": "10",
        "load_name": "tip_type",
        "label": "tiprack300"
      }
    ],
    "pipettes": [
      {
        "mount": "m300_mount",
        "model": "p300_multi_gen2",
        "tipracks": [
          "tiprack300"
        ]
      }
    ],
    "modules": [],
    "commands": [
      {
        "command_type": "delay",
        "pipette": "left",
        "seconds": 5
      },
      {
        "command_type": "delay",
        "pipette": "left",
        "seconds": "blot_dwell_time"
      },
      {
        "command_type": "pick_up_tip",
        "pipette": "m300_mount"
      },
      {
        "command_type": "comment",
        "pipette": "left",
        "message": "\"Ghost\" aspirations to ensure all labware is calibrated."
      },
      {
        "command_type": "aspirate",
        "pipette": "m300_mount",
        "volume": 1
      },
      {
        "command_type": "dispense",
        "pipette": "m300_mount",
        "volume": 1
      },
      {
        "command_type": "delay",
        "pipette": "left",
        "seconds": "slide_dwell_time"
      },
      {
        "command_type": "pause",
        "pipette": "left",
        "message": "Protocol complete. Continue descending 20mm before dropping tip?\nIf yes, click 'Resume'.\nIf no, cancel run, and remove tips/pins manually."
      },
      {
        "command_type": "drop_tip",
        "pipette": "m300_mount"
      }
    ]
  }
}