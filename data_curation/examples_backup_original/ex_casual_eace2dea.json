      },
      {
        "slot": "6",
        "load_name": "nest_96_wellplate_2ml_deep",
        "label": "temp_plate"
      }
    ],
    "pipettes": [
      {
        "mount": "right",
        "model": "p300_multi_gen2",
        "tipracks": []
      }
    ],
    "modules": [
      {
        "module_type": "magnetic",
        "slot": "1",
        "label": "magdeck"
      },
      {
        "module_type": "Temperature Module Gen2",
        "slot": "4",
        "label": "tempdeck"
      }
    ],
    "commands": [
      {
        "command_type": "disengage_magnets",
        "module": "magdeck"
      },
      {
        "command_type": "pause",
        "pipette": "left",
        "message": "Please refill tipracks before resuming."
      },
      {
        "command_type": "set_temperature",
        "module": "tempdeck",
        "celsius": 65
      },
      {
        "command_type": "pause",
        "pipette": "left",
        "message": "Homogenize samples, then return plate tempdeck on robot."
      },
      {
        "command_type": "delay",
        "pipette": "left",
        "seconds": 600
      },
      {
        "command_type": "pick_up_tip",
        "pipette": "right"
      },
      {
        "command_type": "transfer",
        "pipette": "right",
        "volume": 200,
        "source_labware": "",
        "source_well": "A1",
        "dest_labware": "",
        "dest_well": "A1",
        "new_tip": "never"
      },
      {
        "command_type": "blow_out",
        "pipette": "right"
      },
      {
        "command_type": "drop_tip",
        "pipette": "right"
      },
      {
        "command_type": "pause",
        "pipette": "left",
        "message": "Incubate on ice for 5 minutes, then return plate to deck.\n            Replace lysis buffer A with wash buffer 1."
      },
      {
        "command_type": "engage_magnets",
        "module": "magdeck"
      },
      {
        "command_type": "delay",
        "pipette": "left",
        "seconds": 300
      },
      {
        "command_type": "disengage_magnets",
        "module": "magdeck"
      },
      {
        "command_type": "pause",
        "pipette": "left",
        "message": "Vortex plate for 1 minute at 750 RPM,\n         then replace onto magdeck. Replace ethanol with wash buffer 2."
      },
      {
        "command_type": "engage_magnets",
        "module": "magdeck"
      },
      {
        "command_type": "delay",
        "pipette": "left",
        "seconds": 120
      },
      {
        "command_type": "disengage_magnets",
        "module": "magdeck"
      },
      {
        "command_type": "engage_magnets",
        "module": "magdeck"
      },
      {
        "command_type": "delay",
        "pipette": "left",
        "seconds": 120
      },
      {
        "command_type": "delay",
        "pipette": "left",
        "seconds": 300
      },
      {
        "command_type": "disengage_magnets",
        "module": "magdeck"
      },
      {
        "command_type": "set_temperature",
        "module": "tempdeck",
        "celsius": 70
      },
      {
        "command_type": "pause",
        "pipette": "left",
        "message": "Vortex plate, then return to tempdeck on robot"
      },
      {
        "command_type": "delay",
        "pipette": "left",
        "seconds": 300
      },
      {
        "command_type": "pause",
        "pipette": "left",
        "message": "Return plate to magdeck. Replace original\n             plate at position 6 with a new skirted plate"
      },
      {
        "command_type": "engage_magnets",
        "module": "magdeck"
      },
      {
        "command_type": "delay",
        "pipette": "left",
        "seconds": 300
      }
    ]
  }
