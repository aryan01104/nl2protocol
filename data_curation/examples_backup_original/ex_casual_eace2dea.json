    "author": "Chaz <chaz@opentrons.com>",
    "labware": [
      {
        "slot": "6",
        "load_name": "nest_96_wellplate_2ml_deep",
        "label": "plate"
      },
      {
        "slot": "3",
        "load_name": "nest_12_reservoir_15ml",
        "label": "reagents"
      },
      {
        "slot": "deepwell plate",
        "load_name": "nest_96_wellplate_2ml_deep",
